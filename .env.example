# Ollama server (default: local)
# When running inside a devcontainer, use host.docker.internal instead:
#   OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_HOST=http://localhost:11434

# Model used for generating embeddings (must be pulled in Ollama)
EMBED_MODEL=nomic-embed-text

# Model used for generating responses (must be pulled in Ollama)
LLM_MODEL=llama3.2

# Where ChromaDB persists data
CHROMA_DIR=~/.botscrum/chroma

# Chunking settings
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Number of chunks retrieved per query
TOP_K=5
